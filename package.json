{
  "name": "@organigram/react",
  "version": "0.1.4",
  "description": "React hooks and components for the Organigram protocol.",
  "author": "Organigram (https://organigram.ai)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "ssh://git@github.com:organigram/organigram.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "type": "module",
  "peerDependencies": {
    "@mui/icons-material": "^5.18.0",
    "@mui/material": "^5.15.4",
    "@organigram/js": "workspace:^",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-flow-renderer": "^10.3.17",
    "react-i18next": "^11.0.0",
    "recoil": "^0.7.7",
    "viem": "^2.18.2"
  },
  "dependencies": {
    "@organigram/js": "workspace:^",
    "dagre": "^0.8.5"
  },
  "scripts": {
    "build": "vite build",
    "docs:generate": "env-cmd --silent tsx ./scripts/docs.ts",
    "dev": "vite dev",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit --incremental false",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@mui/icons-material": "^5.18.0",
    "@organigram/js": "workspace:^",
    "@types/dagre": "^0.7.53",
    "@types/node": "^20.19.37",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "4.1.8",
    "playwright": "^1.60.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-flow-renderer": "^10.3.17",
    "react-i18next": "^15.0.0",
    "recoil": "^0.7.7",
    "typescript": "^5.5.4",
    "viem": "^2.18.2",
    "vite": "^7.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.8",
    "vitest-browser-react": "^2.0.2"
  },
  "gitHead": "5aeceb89fcac23a06b21969c01c8bfdd36cea896"
